---
import { business } from '../data/business';
import { services } from '../data/services';
---
<header id="site-header" class="bg-surface/95 backdrop-blur-sm border-b border-line sticky top-0 z-50 transition-shadow duration-300">
  <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-20">
    <a href="/" class="flex items-center gap-3 min-w-0">
      <img src="/images/logo.png" alt={business.name} class="h-16 w-auto object-contain flex-shrink-0" />
      <span class="font-bold text-xl text-ink truncate">{business.name}</span>
    </a>
    <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
      <a href="/" class="text-body hover:text-ink">Home</a>
      <div class="relative group">
        <button class="text-body hover:text-ink flex items-center gap-1">
          Services <span class="text-xs">▾</span>
        </button>
        <div class="absolute left-0 top-full hidden group-hover:block bg-card border border-line rounded shadow-lg py-2 min-w-48 z-10">
          {services.map(s => (
            <a href={'/services/' + s.slug + '/'} class="block px-4 py-2 text-sm text-body hover:bg-surface-alt">{s.title}</a>
          ))}
        </div>
      </div>
      <a href="/about/" class="text-body hover:text-ink">About</a>
      
      <a href="/contact/" class="text-body hover:text-ink">Contact</a>
    </nav>
    <div class="flex items-center gap-3">
      <a href={'tel:' + business.phone}
        class="bg-accent text-white px-4 py-2 rounded font-semibold text-sm hover:bg-accent-dark transition-colors whitespace-nowrap">
        {business.phone}
      </a>
      <button id="nav-toggle" class="md:hidden p-2 rounded text-body hover:bg-surface-alt" aria-label="Menu">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="19" y2="6"/><line x1="3" y1="12" x2="19" y2="12"/><line x1="3" y1="18" x2="19" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
  <div id="mobile-nav" class="hidden md:hidden bg-surface border-t border-line px-4 pb-4">
    <a href="/" class="block py-3 text-body border-b border-line font-medium">Home</a>
    <a href="/services/" class="block py-3 text-body border-b border-line font-medium">Services</a>
    <a href="/about/" class="block py-3 text-body border-b border-line font-medium">About</a>
    
    <a href="/contact/" class="block py-3 text-body font-medium">Contact</a>
  </div>
</header>
<script>
  const btn = document.getElementById('nav-toggle');
  const nav = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => nav?.classList.toggle('hidden'));
  const h = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    h?.classList.toggle('shadow-lg', window.scrollY > 60);
    h?.classList.toggle('border-line', window.scrollY <= 60);
  }, { passive: true });
</script>
