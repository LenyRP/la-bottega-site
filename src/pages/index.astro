---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { business } from '../data/business';
import { areas } from '../data/areas';

const faqs = [
    { q: "Do you take reservations in Palatka?", a: "Yes — online reservations available at all times, or call us directly. Walk-ins welcome based on availability." },
    { q: "Do you offer gluten-free or vegetarian options?", a: "We have clearly marked menu items for dietary needs. Ask your server and we'll accommodate wherever possible." },
    { q: "Do you cater for events?", a: "Yes — we offer off-site catering throughout the Palatka area. Contact us with your date, headcount, and menu preferences." },
    { q: "What are your hours?", a: "See our current hours on Google or give us a call — holiday hours may vary." },
    { q: "Is parking available?", a: "Yes, we have on-site parking. Additional street parking is available nearby." }
];
---
<BaseLayout
  title={"La Bottega | Palatka, FL — Free Estimates"}
  description={"La Bottega is a Coffee & Wine Bar serving Italian eats, tapas, and daily rotating Italian-style meals. Our menu changes daily and may include dishes such as Fettuccine Alfredo, Chicken Tortellini, Italian-style baby back ribs “Costalletas,” and other European-inspired plates. So whether you’re stopping in for coffee, wine, small plates, or one of our daily dinner features, we’d love to welcome you in."}
>

  <!-- Hero -->
  <section class="relative text-white overflow-hidden" style="min-height:520px;background:linear-gradient(rgba(0,0,0,0.55),rgba(0,0,0,0.55)),url('/images/hero.jpg') center/cover no-repeat;">
    <div class="relative max-w-5xl mx-auto px-6 py-24 text-center flex flex-col items-center justify-center" style="min-height:520px;">
      <p class="uppercase tracking-widest text-sm font-semibold mb-4 opacity-80" style="color:var(--color-accent)">Palatka, FL</p>
      <h1 class="font-display text-5xl md:text-6xl font-bold mb-5 leading-tight">La Bottega</h1>
      <p class="text-xl text-gray-200 mb-10 max-w-2xl">Casual coffee, wine bar, tapas and Italian comfort food</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={'tel:' + business.phone}
          class="font-bold px-8 py-4 rounded-lg text-lg transition-all duration-200 hover:scale-105"
          style="background:var(--color-accent);color:#fff">
          Call {business.phone}
        </a>
        
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <div class="bg-deep text-white py-4 px-4">
    <div class="max-w-5xl mx-auto flex flex-wrap justify-center gap-6 text-sm font-medium">
      
      <span class="flex items-center gap-2"><span style="color:var(--color-accent)">🏠</span> Family-Owned</span>
      <span class="flex items-center gap-2"><span style="color:var(--color-accent)">⭐</span> Top-Rated</span>
      <span class="flex items-center gap-2"><span style="color:var(--color-accent)">🍳</span> Fresh Daily</span>
      <span class="flex items-center gap-2"><span style="color:var(--color-accent)">📍</span> Locally Owned</span>
      <span class="flex items-center gap-2"><span style="color:var(--color-accent)">❤️</span> Community Favorite</span>
    </div>
  </div>

  <!-- Services -->
  <section class="py-20 px-4 bg-surface-alt">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="font-display text-4xl font-bold text-ink mb-3 reveal">What We Serve</h2>
        <p class="text-muted max-w-xl mx-auto reveal reveal-delay-1">Delicious food made with care — served fresh every day.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <div class="service-card reveal reveal-delay-1">
      
      <h3 class="font-bold text-lg text-ink mb-2">Dine-In Experience</h3>
      <p class="text-muted text-sm leading-relaxed">Relaxed, welcoming dining room with attentive service and a full menu.</p>
    </div>
    <div class="service-card reveal reveal-delay-2">
      
      <h3 class="font-bold text-lg text-ink mb-2">Takeout & Online Orders</h3>
      <p class="text-muted text-sm leading-relaxed">Order online or call ahead — ready when you are.</p>
    </div>
    <div class="service-card reveal reveal-delay-3">
      
      <h3 class="font-bold text-lg text-ink mb-2">Catering Services</h3>
      <p class="text-muted text-sm leading-relaxed">Off-site catering for corporate events, weddings, and parties.</p>
    </div>
    <div class="service-card reveal reveal-delay-4">
      
      <h3 class="font-bold text-lg text-ink mb-2">Private Dining & Events</h3>
      <p class="text-muted text-sm leading-relaxed">Private room available for business dinners, celebrations, and group events.</p>
    </div>
    <div class="service-card reveal reveal-delay-5">
      
      <h3 class="font-bold text-lg text-ink mb-2">Lunch Specials</h3>
      <p class="text-muted text-sm leading-relaxed">Rotating weekday lunch menu with daily specials and quick service.</p>
    </div>
    <div class="service-card reveal reveal-delay-6">
      
      <h3 class="font-bold text-lg text-ink mb-2">Dinner Menu</h3>
      <p class="text-muted text-sm leading-relaxed">Full dinner service with appetizers, entrées, and desserts.</p>
    </div>
    <div class="service-card reveal reveal-delay-7">
      
      <h3 class="font-bold text-lg text-ink mb-2">Weekend Brunch</h3>
      <p class="text-muted text-sm leading-relaxed">Saturday and Sunday brunch with bottomless options and family favorites.</p>
    </div>
    <div class="service-card reveal reveal-delay-8">
      
      <h3 class="font-bold text-lg text-ink mb-2">Kids & Family Menu</h3>
      <p class="text-muted text-sm leading-relaxed">Kid-friendly options and family-sized portions for everyone at the table.</p>
    </div>
    <div class="service-card reveal reveal-delay-9">
      
      <h3 class="font-bold text-lg text-ink mb-2">Gift Cards & Parties</h3>
      <p class="text-muted text-sm leading-relaxed">Gift cards available online and in-store. Birthday party packages available.</p>
    </div>
      </div>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="wave-divider bg-surface-alt" style="margin-bottom:-2px">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="width:100%;height:60px;display:block">
      <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>

  <!-- Photo Gallery -->
  <section class="py-16 px-4 bg-surface">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-center text-ink mb-10 reveal">Take a Look Inside</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="overflow-hidden rounded-xl aspect-video reveal reveal-delay-1"><img src="/images/photo1.jpg" alt={business.name} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" /></div>
        <div class="overflow-hidden rounded-xl aspect-video reveal reveal-delay-2"><img src="/images/photo2.jpg" alt={business.name} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" /></div>
        <div class="overflow-hidden rounded-xl aspect-video reveal reveal-delay-3"><img src="/images/photo3.jpg" alt={business.name} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" /></div>
      </div>
    </div>
  </section>





  <!-- Why Choose Us -->
  <section class="py-20 px-4 bg-surface">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-accent font-semibold uppercase tracking-widest text-sm mb-3">Why Dine With Us</p>
          <h2 class="font-display text-4xl font-bold text-ink mb-5 reveal">La Bottega</h2>
          <p class="text-body leading-relaxed mb-8">La Bottega is a Coffee & Wine Bar serving Italian eats, tapas, and daily rotating Italian-style meals. Our menu changes daily and may include dishes such as Fettuccine Alfredo, Chicken Tortellini, Italian-style baby back ribs “Costalletas,” and other European-inspired plates. So whether you’re stopping in for coffee, wine, small plates, or one of our daily dinner features, we’d love to welcome you in.</p>
          <div class="space-y-4">
            {[
              
              'Family-owned and operated',
              'Made-from-scratch recipes daily',
              'Fresh, locally sourced ingredients',
              'Open 7 days a week — come as you are',
            ].map(item => (
              <div class="flex items-start gap-3">
                <span class="mt-0.5 w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 text-white text-xs font-bold" style="background:var(--color-accent)">✓</span>
                <span class="text-body">{item}</span>
              </div>
            ))}
          </div>
          <a href="/contact/" class="mt-8 inline-block font-bold px-8 py-3 rounded-lg transition-all duration-200 hover:scale-105" style="background:var(--color-accent);color:#fff">
            Get a Free Quote
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4">

          <div class="bg-surface-alt rounded-2xl p-6 text-center reveal">
            <div class="text-3xl font-bold mb-1 stat-num" data-target="5" data-suffix="★"
              style="color:var(--color-accent)">0★</div>
            <div class="text-sm text-muted font-medium">Customer Rating</div>
          </div>

          <div class="bg-surface-alt rounded-2xl p-6 text-center reveal">
            <div class="text-3xl font-bold mb-1 stat-num"
              style="color:var(--color-accent)">Fresh</div>
            <div class="text-sm text-muted font-medium">Made Daily</div>
          </div>

          <div class="bg-surface-alt rounded-2xl p-6 text-center reveal">
            <div class="text-3xl font-bold mb-1 stat-num"
              style="color:var(--color-accent)">Local</div>
            <div class="text-sm text-muted font-medium">Community-First</div>
          </div>

          <div class="bg-surface-alt rounded-2xl p-6 text-center reveal">
            <div class="text-3xl font-bold mb-1 stat-num"
              style="color:var(--color-accent)">Family</div>
            <div class="text-sm text-muted font-medium">Owned & Operated</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-16 px-4 bg-surface-alt">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-display text-3xl font-bold text-ink mb-2 reveal">Find Us</h2>
      <p class="text-muted mb-8 reveal">We're right in your neighborhood</p>
      <div class="flex flex-wrap justify-center gap-3">
        {areas.map(a => (
          <a href={'/areas/' + a.slug + '/'} class="px-5 py-2.5 rounded-full text-sm font-semibold border-2 transition-all duration-200 hover:scale-105" style="border-color:var(--color-accent);color:var(--color-accent);background:var(--color-accent-light)">
            {a.city}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-20 px-4 bg-surface">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-display text-4xl font-bold text-ink mb-10 text-center reveal">Frequently Asked Questions</h2>
      <FAQAccordion faqs={faqs} />
    </div>
  </section>

    <!-- Reviews -->
  <section class="py-20 px-4 bg-surface-alt">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display text-4xl font-bold text-center text-ink mb-3 reveal">What Our Customers Say</h2>
      <p class="text-center text-muted mb-12 reveal">Real words from real customers</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <div class="bg-card rounded-2xl p-6 shadow-sm border border-line flex flex-col gap-3 reveal reveal-delay-1">
      <div class="text-yellow-400 text-xl">★★★★★</div>
      <p class="text-body italic leading-relaxed">&ldquo;This new place in Palatka is so delicious. I'm glad I got a chance to try it over the weekend. Food is great, service was excellent, and the live music set up the atmosphere.&rdquo;</p>
      <div class="mt-auto">
        <div class="font-semibold text-ink">— Regina Correa-Murphy</div>
        <div class="text-xs text-faint mt-0.5">Google</div>
      </div>
    </div>
    <div class="bg-card rounded-2xl p-6 shadow-sm border border-line flex flex-col gap-3 reveal reveal-delay-2">
      <div class="text-yellow-400 text-xl">★★★★★</div>
      <p class="text-body italic leading-relaxed">&ldquo;La Bottega Coffee & Wine Bar/ Italian Eats Ribbon Cutting Ceremony.✂️
A pleasant evening was enjoyed by some on the outside patio with the acoustical sounds of Vinny Jacobs while others chose to gather indoors amongst casual conversation. Congratulations to Chef Jeff and La Bottega!&rdquo;</p>
      <div class="mt-auto">
        <div class="font-semibold text-ink">— Putnam County Chamber of Commerce</div>
        <div class="text-xs text-faint mt-0.5">Google</div>
      </div>
    </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<script>
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Stat counters
  document.querySelectorAll('.stat-num[data-target]').forEach(el => {
    const target = parseFloat(el.dataset.target);
    const suffix = el.dataset.suffix || '';
    const obs = new IntersectionObserver(([e]) => {
      if (!e.isIntersecting) return;
      obs.unobserve(el);
      let start = 0;
      const duration = 1200;
      const step = (timestamp) => {
        if (!start) start = timestamp;
        const progress = Math.min((timestamp - start) / duration, 1);
        const ease = 1 - Math.pow(1 - progress, 3);
        const val = Math.round(target * ease);
        el.textContent = val + suffix;
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    }, { threshold: 0.5 });
    obs.observe(el);
  });
</script>
